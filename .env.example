# Peak Signal — environment variables (spec §5).
# Every integration falls back to mock data when its key is absent, so the app
# runs with this file empty. Copy to .env.local and fill in to go live.

# --- Database (PostgreSQL + Prisma, e.g. Neon) ---
DATABASE_URL=        # pooled connection string
DIRECT_URL=          # direct (non-pooled) string — used for prisma migrate

# --- Auth (Neon Auth — Better Auth; Google OAuth) ---
# Enable Neon Auth on the project, then `neonctl env pull` populates
# NEON_AUTH_BASE_URL and NEON_AUTH_JWKS_URL. Configure Google sign-in in the
# Neon Console (Project → Auth); Neon provides dev OAuth credentials out of the box.
NEON_AUTH_BASE_URL=
NEON_AUTH_JWKS_URL=
NEON_AUTH_COOKIE_SECRET=     # `openssl rand -base64 32`

# --- Cache (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- RapidAPI (flights + hotels via booking-com15; Airbnb via airbnb19) ---
# One key, separate per-API subscriptions. Airbnb scraper is fragile, see README.
RAPIDAPI_KEY=
RAPIDAPI_BOOKING_HOST=
RAPIDAPI_AIRBNB_HOST=

# --- Experiences (Viator / GetYourGuide affiliate APIs) ---
VIATOR_API_KEY=
GETYOURGUIDE_API_KEY=

# --- Gemini (itinerary generation) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash   # optional override

# --- Resend (email alerts) ---
RESEND_API_KEY=
RESEND_FROM=         # verified sender, e.g. "Peak Signal <alerts@yourdomain.com>";
                     # defaults to onboarding@resend.dev (delivers only to your own account email)

# --- Cron (scheduled price poller) ---
# Shared secret between netlify/functions/price-poller.mts and /api/cron/poll.
# Set the same value in the Netlify environment. `openssl rand -hex 32`
CRON_SECRET=

# --- Mapbox (itinerary map) ---
NEXT_PUBLIC_MAPBOX_TOKEN=   # PUBLIC token (pk.…) — sk. secret tokens don't work in browsers
