# Peak Signal — environment variables (spec §5).
# Every integration falls back to mock data when its key is absent, so the app
# runs with this file empty. Copy to .env.local and fill in to go live.

# --- Database (PostgreSQL + Prisma, e.g. Neon) ---
DATABASE_URL=        # pooled connection string
DIRECT_URL=          # direct (non-pooled) string — used for prisma migrate

# --- Auth (NextAuth.js + Google OAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=     # `openssl rand -base64 32`
# Google Cloud Console → Credentials → OAuth client ID (Web application).
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cache (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Amadeus (flights + hotels) — free self-service test env ---
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_HOST=test.api.amadeus.com

# --- Airbnb (RapidAPI scraper) — fragile, see README ---
RAPIDAPI_KEY=
RAPIDAPI_AIRBNB_HOST=

# --- Experiences (Viator / GetYourGuide affiliate APIs) ---
VIATOR_API_KEY=
GETYOURGUIDE_API_KEY=

# --- GEMINI API (itinerary generation) ---
GEMINI_API_KEY=

# --- Resend (email alerts) ---
RESEND_API_KEY=

# --- Mapbox (itinerary map) ---
NEXT_PUBLIC_MAPBOX_TOKEN=
