// Copy this file to Secrets.xcconfig and fill in your keys.
// Secrets.xcconfig is gitignored — never commit real credentials.
//
// Referenced from project.yml (configFiles) and read at runtime via
// Bundle.main.object(forInfoDictionaryKey:) after mapping into Info.plist,
// or injected through AppConfig.swift.

// Amadeus — free self-service test environment, no approval needed.
// https://developers.amadeus.com  (Self-Service > My Apps)
AMADEUS_CLIENT_ID =
AMADEUS_CLIENT_SECRET =
// test.api.amadeus.com (test) or api.amadeus.com (production)
AMADEUS_HOST = test.api.amadeus.com

// RapidAPI — Airbnb scraper endpoint (fragile; see README caveats).
RAPIDAPI_KEY =
RAPIDAPI_AIRBNB_HOST =

// Viator affiliate API. Apply early — approval takes 3–5 business days.
VIATOR_API_KEY =

// GetYourGuide affiliate API.
GETYOURGUIDE_API_KEY =

// Anthropic Claude API — Phase 2 itinerary generation.
// https://console.anthropic.com
ANTHROPIC_API_KEY =
