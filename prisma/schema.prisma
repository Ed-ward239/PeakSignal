// Peak Signal database schema (spec §6.3) + Auth.js (NextAuth) models.
// Activate with a Neon DATABASE_URL: `npx prisma migrate dev`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Neon: direct (non-pooled) URL for migrations
}

// ---- Auth ----
// Users/sessions are managed by Neon Auth (Better Auth) in the managed
// `neon_auth` schema (read-only `neon_auth.users_sync`). App tables reference the
// user by id string only — no Prisma-managed User table or foreign key.

// ---- Peak Signal app models ----

// Per-user notification preferences (Settings page). Read by the cron poller to
// decide which emails to send and how often. Keyed by the Neon Auth user id.
model UserSettings {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  emailPriceDrop Boolean  @default(true) @map("email_price_drop") // price falls below target
  emailBuySignal Boolean  @default(true) @map("email_buy_signal") // verdict flips to BUY
  weeklyDigest   Boolean  @default(false) @map("weekly_digest") // weekly price summary
  frequency      String   @default("instant") // instant | daily | weekly
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

model WatchedTrip {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  origin          String
  destination     String
  destinationName String         @map("destination_name")
  departDate      DateTime       @map("depart_date")
  returnDate      DateTime       @map("return_date")
  targetPrice     Float?         @map("target_price")
  travellers      Int            @default(1)
  isBooking       Boolean        @default(false) @map("is_booking")
  // Traveller-picked flights ({ outbound?, return? } as client Flight JSON) —
  // the itinerary planner reads their arrival/departure times.
  selectedFlights Json?          @map("selected_flights")
  createdAt       DateTime       @default(now()) @map("created_at")
  prices          PriceHistory[]
  verdicts        Verdict[]
  itineraries     Itinerary[]
  sharedLinks     SharedLink[]

  @@map("watched_trips")
}

model PriceHistory {
  id        String      @id @default(cuid())
  tripId    String      @map("trip_id")
  trip      WatchedTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category  String
  price     Float
  currency  String      @default("USD")
  checkedAt DateTime    @default(now()) @map("checked_at")

  @@index([tripId, category, checkedAt])
  @@map("price_history")
}

model Verdict {
  id             String      @id @default(cuid())
  tripId         String      @map("trip_id")
  trip           WatchedTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  signal         String
  pctVsAverage   Float       @map("pct_vs_average")
  recommendation String
  computedAt     DateTime    @default(now()) @map("computed_at")

  @@map("verdicts")
}

// One itinerary per trip; `payload` is the full client Itinerary object (days,
// slots, preTrip checklist, flightAware, profile). Signed-in users only —
// guests keep itineraries in sessionStorage (gone when the browser closes).
model Itinerary {
  id          String      @id @default(cuid())
  tripId      String      @unique @map("trip_id")
  trip        WatchedTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  payload     Json
  generatedAt DateTime    @default(now()) @map("generated_at")
  shareToken  String?     @unique @map("share_token")

  @@map("itineraries")
}

model SharedLink {
  id        String      @id @default(cuid())
  tripId    String      @map("trip_id")
  trip      WatchedTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  token     String      @unique
  expiresAt DateTime    @map("expires_at")
  viewCount Int         @default(0) @map("view_count")

  @@map("shared_links")
}
